  "private": true,
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "build:search": "tsx scripts/build-search-index.ts",
    "import:old": "tsx scripts/import-old-html.ts",
    "dev": "next dev",
    "build": "npm run build:data && npm run build:search && next build",
