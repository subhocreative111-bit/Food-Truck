# Copy this file to .env.local and fill in your Supabase project credentials.
# Both values are PUBLIC — they ship in the client bundle. That's fine because
# Supabase's Row-Level Security (RLS) is the real security layer, not the key.
#
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
