# Hostinger / Apache static-export config

RewriteEngine On

# Canonical hostname — 301 redirect www → non-www.
# Critical for SEO: without this, Google and Ahrefs see two copies of every
# page (www.foodtrucksnearmeusa.com/X and foodtrucksnearmeusa.com/X), causing
# duplicate-content warnings and diluted rankings.
RewriteCond %{HTTP_HOST} ^www\.foodtrucksnearmeusa\.com$ [NC]
RewriteRule ^(.*)$ https://foodtrucksnearmeusa.com/$1 [R=301,L]

# Force HTTPS (belt-and-suspenders — Hostinger usually handles this at the
# load balancer, but make sure it's enforced if a plain-HTTP request slips in)
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Legacy URL preservation: the previous static HTML site lived at
# /pages/food-trucks-in-<state>.html. Google has these indexed and is still
# sending traffic to them. 301-redirect to the equivalent Next.js state page
# so we inherit the existing impressions, age and link equity instead of
# letting users land on a 404. (Reported via GSC recommendation on 4 Jun 2026
# for the Maryland page, with a 764% impressions spike on the dead URL.)
RewriteRule ^pages/food-trucks-in-([a-z0-9-]+)\.html$ /states/$1/ [R=301,L,NC]

# Strip trailing slashes on file requests (Next exports trailing slashes on routes)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Custom 404
ErrorDocument 404 /404.html

# Cache static assets aggressively
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg     "access plus 1 year"
  ExpiresByType image/png      "access plus 1 year"
  ExpiresByType image/webp     "access plus 1 year"
  ExpiresByType image/svg+xml  "access plus 1 year"
  ExpiresByType text/css       "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2     "access plus 1 year"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain application/json image/svg+xml
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
