# Dependencies
node_modules/

# Build output
.next/
out/
*.tsbuildinfo

# Generated data
# trucks.json IS committed — it's the source of truth for production builds.
# Hostinger reads it directly, skipping regeneration. Regenerate locally with
# `npm run build:data` (uses outscraper-merged.json) or `npm run import:old`.
# Source files (xlsx) and intermediates are gitignored — too big and only
# needed for local re-import workflows.
public/search-index.json
data/outscraper-merged.json
data/trucks.json.backup-seed
data/*.xlsx
data/*.xls
data/*.csv

# Environment
.env*
!.env.example

# Logs
*.log
npm-debug.log*

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code per-machine tool permissions (track .claude/launch.json only)
.claude/settings.local.json
